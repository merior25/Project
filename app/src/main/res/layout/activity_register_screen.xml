<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EBF5FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal"
        android:layoutDirection="rtl">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/playfair_display_medium_italic"
            android:text="Worki"
            android:textColor="#111827"
            android:textSize="56sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="יצירת חשבון חדש"
            android:textSize="16sp"
            android:textColor="#546E7A"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/firstNameInputRegister"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="שם פרטי"
            android:textColorHint="#9CA3AF"
            android:inputType="textPersonName"
            android:background="@drawable/input_bg_solid"
            android:gravity="right|center_vertical"
            android:textDirection="rtl"
            android:paddingRight="24dp"
            android:paddingLeft="24dp"
            android:textColor="#111827"
            android:elevation="2dp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/lastNameInputRegister"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="שם משפחה"
            android:textColorHint="#9CA3AF"
            android:inputType="textPersonName"
            android:background="@drawable/input_bg_solid"
            android:gravity="right|center_vertical"
            android:textDirection="rtl"
            android:paddingRight="24dp"
            android:paddingLeft="24dp"
            android:textColor="#111827"
            android:elevation="2dp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/editTextPhone"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="מספר טלפון"
            android:textColorHint="#9CA3AF"
            android:inputType="phone"
            android:background="@drawable/input_bg_solid"
            android:gravity="right|center_vertical"
            android:textDirection="rtl"
            android:paddingRight="24dp"
            android:paddingLeft="24dp"
            android:textColor="#111827"
            android:elevation="2dp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/emailInputRegister"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="אימייל"
            android:textColorHint="#9CA3AF"
            android:inputType="textEmailAddress"
            android:background="@drawable/input_bg_solid"
            android:gravity="right|center_vertical"
            android:textDirection="rtl"
            android:paddingRight="24dp"
            android:paddingLeft="24dp"
            android:textColor="#111827"
            android:elevation="2dp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/passwordInputRegister"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="סיסמה"
            android:textColorHint="#9CA3AF"
            android:inputType="textPassword"
            android:background="@drawable/input_bg_solid"
            android:gravity="right|center_vertical"
            android:textDirection="rtl"
            android:paddingRight="24dp"
            android:paddingLeft="24dp"
            android:textColor="#111827"
            android:elevation="2dp"
            android:layout_marginBottom="24dp" />

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="right|center_vertical" android:layoutDirection="rtl"
            android:layout_marginBottom="32dp">

            <RadioButton
                android:id="@+id/radioButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="אני עסק"
                android:textColor="#111827"
                android:textSize="16sp"
                android:layoutDirection="rtl" android:layout_marginEnd="32dp"/>

            <RadioButton
                android:id="@+id/radioButton2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layoutDirection="rtl"
                android:text="אני עובד"
                android:textColor="#111827"
                android:textSize="16sp" />
        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/registerButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="הרשמה"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#111827"
            app:cornerRadius="30dp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>