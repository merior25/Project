<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:layoutDirection="rtl"
    android:background="#EBF5FB">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="לוח גיוס עובדים"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:layout_marginBottom="8dp"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvRecruitProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E8F5E9"
        android:padding="12dp"
        android:textColor="#2E7D32"
        android:textStyle="bold"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        android:text="טוען התקדמות גיוס..." />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScheduledInterviews"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="55dp"
            android:text="ראיונות"
            android:layout_marginEnd="4dp"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInbox"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="55dp"
            android:text="זימונים"
            android:layout_marginStart="4dp"
            app:backgroundTint="#2196F3"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- מכולה לרשימות כדי למנוע הסתרה של כפתור הסגירה -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="מועמדים פוטנציאליים:"
            android:textColor="#333333"
            android:layout_marginBottom="4dp"/>

        <ListView
            android:id="@+id/workersListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:divider="#E5E7EB"
            android:dividerHeight="1dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="עובדים שהתקבלו:"
            android:textColor="#333333"
            android:layout_marginBottom="4dp"/>

        <ListView
            android:id="@+id/hiredListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F8F9FA"
            android:elevation="2dp"
            android:divider="#E5E7EB"
            android:dividerHeight="1dp"
            android:layout_marginBottom="12dp" />
    </LinearLayout>

    <!-- הכפתור התחתון תמיד יישאר על המסך -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="סגירת הגיוס ומעבר לעריכה"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        app:backgroundTint="#374151"
        app:cornerRadius="12dp" />

</LinearLayout>