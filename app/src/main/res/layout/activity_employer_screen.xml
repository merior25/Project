<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:layoutDirection="rtl"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/greetingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="שלום, "
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnRecruit"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="פתיחת גיוס חדש"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#000000"
        android:layout_marginBottom="16dp" />

    <!-- המכולה הזו מבטיחה שהרשימות יתפסו רק את המקום שנשאר ולא ידחפו דברים החוצה -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="גיוסים פעילים:"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <ListView
            android:id="@+id/jobsListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="כל העובדים שגייסתי:"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <ListView
            android:id="@+id/allHiredWorkersListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F8F9FA"
            android:elevation="1dp" />
    </LinearLayout>

</LinearLayout>