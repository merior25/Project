<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EBF5FB"
    tools:context=".EmployerSetupScreen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal"
        android:layoutDirection="rtl">

        <TextView
            android:id="@+id/tvSetupTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="הגדרת פרופיל עסק"
            android:textColor="#111827"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSetupSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="כדי שנוכל להתחיל, ספרו לנו קצת על העסק"
            android:textColor="#546E7A"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginBottom="40dp" />

        <EditText
            android:id="@+id/editBusinessName"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="שם העסק / החברה"
            android:textColorHint="#9CA3AF"
            android:inputType="text"
            android:background="@drawable/input_bg_solid"
            android:gravity="right|center_vertical"
            android:textDirection="rtl"
            android:paddingRight="24dp"
            android:paddingLeft="24dp"
            android:textColor="#111827"
            android:elevation="2dp"
            android:layout_marginBottom="16dp" />

        <Spinner
            android:id="@+id/spinnerBusinessCategory"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/input_bg_solid"
            android:elevation="2dp"
            android:paddingRight="16dp"
            android:paddingLeft="16dp"
            android:layoutDirection="rtl"
            android:textDirection="rtl"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/editBusinessLocation"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="עיר פעילות"
            android:textColorHint="#9CA3AF"
            android:inputType="text"
            android:background="@drawable/input_bg_solid"
            android:gravity="right|center_vertical"
            android:textDirection="rtl"
            android:paddingRight="24dp"
            android:paddingLeft="24dp"
            android:textColor="#111827"
            android:elevation="2dp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/editBusinessDescription"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="ספרו קצת על העסק (אופציונלי)"
            android:textColorHint="#9CA3AF"
            android:inputType="textMultiLine"
            android:background="@drawable/input_bg_solid"
            android:gravity="right|top" android:textDirection="rtl"
            android:padding="20dp"
            android:textColor="#111827"
            android:elevation="2dp"
            android:layout_marginBottom="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveBusinessProfile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="שמור והמשך"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#111827"
            app:cornerRadius="30dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>