<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:layoutDirection="rtl"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="קביעת ראיון"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- הוספנו focusable=false כדי שהמקלדת לא תיפתח, אלא רק החלונית שלנו -->
    <EditText
        android:id="@+id/etDate"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="תאריך ראיון (לחץ לבחירה)"
        android:background="#F0F0F0"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:focusable="false"
        android:clickable="true" />

    <EditText
        android:id="@+id/etTime"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="שעת ראיון (לחץ לבחירה)"
        android:background="#F0F0F0"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:focusable="false"
        android:clickable="true" />

    <EditText
        android:id="@+id/etLocation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="מיקום הראיון / קישור לזום"
        android:background="#F0F0F0"
        android:padding="12dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etDesc"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:gravity="top"
        android:hint="הערות (מה להביא, למי לפנות וכו')"
        android:background="#F0F0F0"
        android:padding="12dp"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSendInterview"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="שלח הצעת ראיון לעובד"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        app:backgroundTint="#4CAF50"
        app:cornerRadius="30dp" />

</LinearLayout>